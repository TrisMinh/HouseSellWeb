# Django deploy/readiness template for HouseSell backend
# Copy to .env (or inject via deployment secret manager)

# Core mode
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-strong-random-secret
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# Database
# Local MySQL example:
# HSW_DB_ENGINE=django.db.backends.mysql
# HSW_DB_NAME=housesell_db
# HSW_DB_USER=root
# HSW_DB_PASSWORD=
# HSW_DB_HOST=localhost
# HSW_DB_PORT=3306

# Render + Supabase session pooler example:
HSW_DB_ENGINE=django.db.backends.postgresql
HSW_DB_NAME=postgres
HSW_DB_USER=postgres.your-project-ref
HSW_DB_PASSWORD=replace-supabase-db-password
HSW_DB_HOST=aws-1-ap-northeast-1.pooler.supabase.com
HSW_DB_PORT=5432
HSW_DB_SSLMODE=require
HSW_DB_SEARCH_PATH=housesell_db,public

# Supabase Storage
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_me
SUPABASE_AVATARS_BUCKET=avatars
SUPABASE_PROPERTY_IMAGES_BUCKET=property-images
SUPABASE_VERIFICATION_DOCS_BUCKET=verification-docs
SUPABASE_NEWS_BUCKET=property-images
SUPABASE_SIGNED_URL_EXPIRES_IN=3600

# Optional alternative: provide a single URL instead of the vars above.
# HSW_DATABASE_URL=postgresql://postgres.your-project-ref:replace-supabase-db-password@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# CORS / CSRF
# Add every frontend origin that will call the API.
# Dev examples:
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:4173,http://127.0.0.1:4173,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
FRONTEND_BASE_URL=https://your-frontend-domain.com

# Email / password reset
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=replace-app-password-or-provider-secret
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=Blue Sky <your-email@example.com>
PASSWORD_RESET_TIMEOUT=1800
# Optional regexes for LAN/dev access, for example:
# CORS_ALLOWED_ORIGIN_REGEXES=^http://192\\.168\\.1\\.\\d+:8080$

# API docs exposure
# true  -> docs accessible publicly
# false -> docs require admin authentication
SWAGGER_PUBLIC=false

# Media policy
PROPERTY_IMAGE_ALLOWED_TYPES=image/jpeg,image/png,image/webp,image/gif
PROPERTY_IMAGE_MAX_UPLOAD_BYTES=5242880
PROPERTY_IMAGE_MAX_FILES_PER_UPLOAD=10
PROPERTY_IMAGE_MAX_FILES_PER_PROPERTY=30
